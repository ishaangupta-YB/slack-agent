# Slack (Socket Mode)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
# Optional user token for Real-Time Search API (assistant.search.context)
SLACK_USER_TOKEN=xoxp-...
# Optional test channel for `npm run verify-slack` to confirm chat:write scope.
# VERIFY_SLACK_TEST_CHANNEL=C1234567890
# Optional end-to-end Slack test channel for `npm run slack-e2e`.
# SLACK_E2E_CHANNEL=C1234567890
# SLACK_E2E_TIMEOUT_MS=60000
# Number of retries (and base backoff) for transient Slack API failures when posting messages.
# SLACK_SAY_RETRIES=2
# SLACK_SAY_RETRY_BASE_MS=1000
# Number of text-like file attachments Moon Bot will read per message (requires files:read scope).
# SLACK_MAX_FILE_ATTACHMENTS=3
# Maximum size (bytes) of a single Slack file attachment to include in the prompt.
# SLACK_MAX_FILE_BYTES=1048576

# GitHub-only mode (optional second pod).
# When GITHUB_ONLY=true, the bot does not connect to Slack. Instead it listens for GitHub
# webhooks and replies to @moon-bot mentions on issues/PRs. SLACK_BOT_TOKEN and
# SLACK_APP_TOKEN are not required in this mode.
# GITHUB_ONLY=false
# GITHUB_WEBHOOK_PORT=3000
# GITHUB_WEBHOOK_SECRET=... # HMAC-SHA256 secret from the GitHub App webhook settings
# Optional allowlists. If set, events from other repos/orgs are ignored.
# GITHUB_ONLY_ALLOWED_REPOS=my-org/repo1,my-org/repo2
# GITHUB_ONLY_ALLOWED_ORGS=my-org

# Cloudflare Workers AI
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_MODEL=@cf/moonshotai/kimi-k2.7-code
# Optional fallback model used when the primary Cloudflare model returns a "not found" error.
# CLOUDFLARE_FALLBACK_MODEL=@cf/moonshotai/kimi-k2.6
# CLOUDFLARE_TIMEOUT_MS=120000
# CLOUDFLARE_RETRIES=2
# Set to true to make `npm run diagnose` and `/moonbot diagnose` perform a live LLM ping.
# DIAGNOSE_LLM_PING=false

# Agent behavior
AGENT_SYSTEM_PROMPT_OVERRIDE=
SESSIONS_DIR=./sessions
MEMORY_FILE=./sessions/memory.json
THREAD_MAP_FILE=./sessions/thread-map.json
MAX_MEMORY_ENTRIES=200
# Number of recent + relevant memory entries automatically injected into the system prompt.
# MEMORY_CONTEXT_ENTRIES=3
# Maximum messages sent to the LLM per turn (0 = unlimited). Keeps long Slack threads from
# exceeding the model context window. The system message is always preserved and tool-call
# / observation pairs are never split.
# AGENT_MAX_CONTEXT_MESSAGES=0
# FEEDBACK_LOG_FILE=./sessions/feedback.jsonl

# Security
ALLOW_BASH=false
# Optional tiered Linux user sandboxing for bash. When set, the bash tool runs
# commands as `su -l <user> -c 'cd /app && command'` so each tier inherits a
# clean environment with only the credentials that user has access to.
# Requires the bot process to run as root and the users to exist on the host.
# BASH_TIER_USERS=basic:mb-runner,elastic:mb-elastic,privileged:mb-privileged
# Disable the root check in development (not recommended in production).
# BASH_REQUIRE_ROOT_FOR_SU=true
# Set to true to allow Slack guest (single/multi-channel) accounts to use Moon Bot.
# Defaults to false to match the access control policy in WRITEUP.md.
ALLOW_GUESTS=false
ALLOWED_USER_IDS=
ADMIN_USER_IDS=
# SECURITY_AUDIT_LOG_FILE=./sessions/audit.jsonl
# SLACK_SECURITY_ALERT_CHANNEL=C1234567890

# Access tiers (basic / elastic / privileged).
# Map Slack user IDs to tiers without Okta: U1234567890:privileged,U9876543210:elastic
USER_TIERS=
# DEFAULT_ACCESS_TIER=basic

# Optional Okta group-based tier resolution.
# OKTA_DOMAIN=your-org.okta.com
# OKTA_API_TOKEN=00...
# OKTA_PRIVILEGED_GROUPS=database-admins,infra-admins
# OKTA_ELASTIC_GROUPS=elasticsearch-users,security-engineers

# Optional integrations
GITHUB_TOKEN=
# GitHub App authentication (recommended): short-lived, narrowly-scoped tokens for PR/issue writes.
# Set GITHUB_APP_ID, GITHUB_PRIVATE_KEY (PEM, may be base64-encoded or JSON-escaped), and
# GITHUB_INSTALLATION_ID. When configured, GitHub tools use the App token; otherwise they fall
# back to the static GITHUB_TOKEN.
# GITHUB_APP_ID=123456
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
# GITHUB_INSTALLATION_ID=12345678
# Optional JSON map from Slack user ID or email to GitHub handle for PR/issue footers.
# GITHUB_USER_MAP={"U1234567890":"alice","bob@example.com":"bob"}
# Number of retries (and base backoff) for transient GitHub API failures.
# GITHUB_API_RETRIES=2
# GITHUB_API_RETRY_BASE_MS=1000
PLAUSIBLE_API_KEY=
# Plausible local credential proxy: exposes localhost:9203 and forwards only POST
# /api/v2/query, injecting the upstream API key server-side. Handed to all tiers.
# PLAUSIBLE_PROXY_PORT=9203
# PLAUSIBLE_PROXY_TOKEN=...
# Optional override for testing (defaults to https://plausible.io)
# PLAUSIBLE_UPSTREAM_URL=https://plausible.io

# Local cloned code repositories (for the search_code tool and hub-code skill)
# CODE_REPOS_DIR=./repos

# Elasticsearch (for es_query tool and scheduled ops reports)
# ES_URL=http://localhost:9200
# ES_API_KEY=...
# ES_USERNAME=
# ES_PASSWORD=
# Local credential proxy: the bot exposes localhost:9201 so that tool calls never
# see the real ES credentials. Set ES_PROXY_TOKEN to a random secret.
# ES_PROXY_PORT=9201
# ES_PROXY_TOKEN=...

# MongoDB (for mongo_query tool)
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DATABASE=hub

# AWS Athena (for athena_query tool)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=... # optional

# Sizzle / DuckDB (for sizzle_query tool and DuckLake Xet storage stats)
# SIZZLE_DATA_DIR=./sizzle
# Local credential proxy for HuggingFace datasets: exposes localhost:9202 and forwards
# only GET requests under the configured dataset repo, injecting HF_TOKEN server-side.
# HF_PROXY_PORT=9202
# HF_PROXY_TOKEN=...
# HF_PROXY_REPO=huggingface/storage-visualization-data
# Optional override for testing (defaults to https://huggingface.co)
# HF_UPSTREAM_URL=https://huggingface.co

# Artifact bucket
# Local filesystem is used by default. To use a HuggingFace Bucket instead, set HF_TOKEN + HF_BUCKET_REPO.
BUCKET_DIR=./bucket
BUCKET_PUBLIC_URL=http://localhost:3001
BUCKET_HTTP_PORT=3001
# HF_TOKEN=hf_...
# HF_BUCKET_REPO=huggingface/moon-bot-memory

# Healthcheck script (src/healthcheck.ts). Used by the Dockerfile HEALTHCHECK.
# HEALTHCHECK_URL=http://localhost:3001/health
# HEALTHCHECK_TIMEOUT_MS=5000
# HEALTHCHECK_RETRIES=0
# HEALTHCHECK_INTERVAL_MS=1000

# Optional MCP (Model Context Protocol) server configuration
# Example: {"filesystem":{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}}
MCP_SERVERS=

# Local CLI overrides (scripts/ask.ts). All are optional and have sensible defaults.
# ASK_THREAD_KEY=cli-my-thread
# ASK_USER_ID=UCLI00000000
# ASK_USER_EMAIL=you@example.com
# ASK_PRINT_THREAD_KEY=true

# Scheduled tasks (disabled if left blank)
SCHEDULED_WEEKLY_REPORT_CHANNEL=
SCHEDULED_DEPLOY_CHANNEL=
# SCHEDULED_DEPLOY_MONITOR_DELAY_MS=900000

# Public status monitor (Agent for Good / civic tech). Moon Bot checks these public
# status-page JSON endpoints on a cron schedule and posts to Slack when an incident is detected.
# STATUS_MONITOR_CHANNEL=C1234567890
# STATUS_MONITOR_PAGES=https://status.cloudflare.com/api/v2/status.json,https://www.githubstatus.com/api/v2/status.json
# STATUS_MONITOR_CRON=*/15 * * * *
# STATUS_MONITOR_STATE_FILE=./sessions/status-monitor-state.json
