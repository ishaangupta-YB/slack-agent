# Slack (Socket Mode)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Cloudflare Workers AI
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_MODEL=@cf/moonshotai/kimi-k2.7-code

# Agent behavior
AGENT_SYSTEM_PROMPT_OVERRIDE=
SESSIONS_DIR=./sessions
MEMORY_FILE=./sessions/memory.json
THREAD_MAP_FILE=./sessions/thread-map.json
MAX_MEMORY_ENTRIES=200

# Security
ALLOW_BASH=false
ALLOWED_USER_IDS=
ADMIN_USER_IDS=

# Optional integrations
GITHUB_TOKEN=
PLAUSIBLE_API_KEY=
